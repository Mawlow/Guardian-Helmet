# Flask (change SECRET_KEY in production)
SECRET_KEY=guardian-helmet-change-me-in-production

# MySQL — XAMPP defaults (edit if your MySQL differs)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=guardian_helmet

# Helmet ESP32 IP (optional; you can also set this in the web app Settings)
# ESP32_IP=

# ESP32-CAM live stream URL for dashboard / Dash cam page
ESP32_CAM_STREAM_URL=http://192.168.1.100/stream

# Admin login (optional overrides)
# FIXED_ADMIN_USERNAME=admin
# FIXED_ADMIN_PASSWORD=admin123

# SMS — Semaphore (used when SEMAPHORE_API_KEY is set)
SEMAPHORE_API_KEY=ee412ef9e321ada2175e3d83d10af3cd
SEMAPHORE_SMS_BASE_URL=https://api.semaphore.co
SEMAPHORE_SSL_VERIFY=0
SEMAPHORE_USE_PRIORITY=1
SEMAPHORE_QUERY_STRING=0
SMS_TIMEZONE=Asia/Manila

# SMS — iProg fallback (only if Semaphore key is empty; leave disabled when using Semaphore)
IPROG_SMS_ENABLED=0
# IPROG_SMS_API_TOKEN=
# IPROG_SMS_BASE_URL=https://sms.iprogtech.com

# Reverse geocode (address in SMS via OpenStreetMap Nominatim)
REVERSE_GEOCODE_ENABLED=1
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=GuardianHelmet/1.0 (accident-alerts)
REVERSE_GEOCODE_TIMEOUT=8
REVERSE_GEOCODE_MAX_CHARS=350

# City/region from helmet’s internet connection (public IP), not the GPS chip
IP_GEOLOCATION_ENABLED=1
IP_API_BASE=http://ip-api.com
# SMS address/map from device network IP only, not helmet GPS (set 1 to use GPS for address)
SMS_USE_HELMET_GPS_FOR_ADDRESS=0

# Second SMS when the dashboard refines a 0,0 alert with browser GPS (same coords as Accident logs)
SMS_ON_LOCATION_UPDATE=1

# Fallback reverse geocoding if Nominatim returns no street/place name (Photon → BigDataCloud)
PHOTON_REVERSE_GEOCODE_ENABLED=1
PHOTON_BASE_URL=https://photon.komoot.io
PHOTON_REVERSE_TIMEOUT=8
BIGDATACLOUD_REVERSE_GEOCODE_ENABLED=1
BIGDATACLOUD_REVERSE_TIMEOUT=6
# BIGDATACLOUD_REVERSE_URL=https://api.bigdatacloud.net/data/reverse-geocode-client