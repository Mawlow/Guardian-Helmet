# Copy to .env and edit. Optional: used when running the Flask server.

# Helmet ESP32 IP — you can also set this in the web app (Settings). Used so the dashboard shows which device is connected.
# Example: 192.168.1.100
# ESP32_IP=

# Live stream from ESP32-CAM (Dash cam page and dashboard). Use your module's IP.
# Example: http://192.168.254.184/stream
ESP32_CAM_STREAM_URL=

# MySQL (defaults work with XAMPP)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=guardian_helmet

# SECRET_KEY=your-secret-key
# chrome://flags/#unsafely-treat-insecure-origin-as-secure

# iProg SMS (guardian SMS alerts on accident)
# Enable/disable SMS sending from Flask /alert handler.
# IPROG_SMS_ENABLED=1
# Your iProg API token from dashboard:
# IPROG_SMS_API_TOKEN=
# Optional API host override
# IPROG_SMS_BASE_URL=https://sms.iprogtech.com

# Semaphore SMS (preferred if SEMAPHORE_API_KEY is set)
# SEMAPHORE_API_KEY=
# Optional API host override
# SEMAPHORE_SMS_BASE_URL=https://api.semaphore.co
# Set 0 to disable TLS cert verification (only for troubleshooting).
# SEMAPHORE_SSL_VERIFY=1
# Use priority route when supported by your account.
# SEMAPHORE_USE_PRIORITY=0
# Send params in query string instead of form body.
# SEMAPHORE_QUERY_STRING=0
# SMS timestamp timezone shown in outgoing messages.
# SMS_TIMEZONE=Asia/Manila

# Reverse geocode — address line in SMS (Nominatim first, then Photon, then BigDataCloud if needed)
# REVERSE_GEOCODE_ENABLED=1
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# NOMINATIM_USER_AGENT=GuardianHelmet/1.0 (your-contact-or-url)
# REVERSE_GEOCODE_TIMEOUT=8
# REVERSE_GEOCODE_MAX_CHARS=350
# PHOTON_REVERSE_GEOCODE_ENABLED=1
# PHOTON_BASE_URL=https://photon.komoot.io
# PHOTON_REVERSE_TIMEOUT=8
# BIGDATACLOUD_REVERSE_GEOCODE_ENABLED=1
# BIGDATACLOUD_REVERSE_TIMEOUT=6
# BIGDATACLOUD_REVERSE_URL=https://api.bigdatacloud.net/data/reverse-geocode-client

# City/region from the helmet’s public IP (device connection), not the GPS module.
# If the helmet is only on LAN (192.168.x.x), the server looks up its own WAN address as a fallback (same building / ISP area).
# IP_GEOLOCATION_ENABLED=1
# IP_API_BASE=http://ip-api.com
# SMS place name + map: 0 = use only network/IP position (default). 1 = prefer helmet GPS lat/lon from JSON for address/map.
# SMS_USE_HELMET_GPS_FOR_ADDRESS=0
# Second SMS when dashboard refines 0,0 alert with device GPS (matches Accident logs map). Set 0 to only send the first SMS.
# SMS_ON_LOCATION_UPDATE=1
