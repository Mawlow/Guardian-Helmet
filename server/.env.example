# Copy to .env and edit. Optional: used when running the Flask server.

# Helmet ESP32 IP — you can also set this in the web app (Settings). Used so the dashboard shows which device is connected.
# Example: 192.168.1.100
# ESP32_IP=

# Live stream from ESP32-CAM (Dash cam page and dashboard). Use your module's IP.
# Example: http://192.168.254.184/stream
ESP32_CAM_STREAM_URL=

# MySQL (defaults work with XAMPP)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=guardian_helmet

# SECRET_KEY=your-secret-key
# chrome://flags/#unsafely-treat-insecure-origin-as-secure

# iProg SMS (guardian SMS alerts on accident)
# Enable/disable SMS sending from Flask /alert handler.
# IPROG_SMS_ENABLED=1
# Your iProg API token from dashboard:
# IPROG_SMS_API_TOKEN=
# Optional API host override
# IPROG_SMS_BASE_URL=https://sms.iprogtech.com

# Semaphore SMS (preferred if SEMAPHORE_API_KEY is set)
# SEMAPHORE_API_KEY=
# Optional API host override
# SEMAPHORE_SMS_BASE_URL=https://api.semaphore.co
# Set 0 to disable TLS cert verification (only for troubleshooting).
# SEMAPHORE_SSL_VERIFY=1
# Use priority route when supported by your account.
# SEMAPHORE_USE_PRIORITY=0
# Send params in query string instead of form body.
# SEMAPHORE_QUERY_STRING=0
